{
  "name": "otg-hmrc-api",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "unit:all": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "unit:aws": "NODE_OPTIONS=--experimental-vm-modules jest --silent --select-projects integration-tests/aws --runInBand",
    "unit:mocked": "NODE_OPTIONS=--experimental-vm-modules jest --silent --select-projects integration-tests/mocked",
    "test:all": "npm run unit:all --",
    "test:aws": "npm run unit:aws --",
    "test:mocked": "npm run unit:mocked --",
    "deploy": "../deploy.sh",
    "compile": "tsc"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "3.1012.0",
    "@aws-sdk/lib-dynamodb": "3.1012.0",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "testcontainers": "11.12.0",
    "ts-jest": "29.2.5"
  }
}
